<!DOCTYPE html>
<html lang="pt-br">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>APO STUDIO V12 | APK & ASSET EDITOR</title>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jszip/3.10.1/jszip.min.js"></script>
    <style>
        :root { --neon: #0f8; --bg: #0a0a0a; --panel: #151515; --accent: #f0f; }
        * { box-sizing: border-box; font-family: 'Consolas', monospace; }
        body { background: var(--bg); color: #ccc; margin: 0; display: flex; flex-direction: column; height: 100vh; overflow: hidden; }

        /* Header */
        header { background: #000; padding: 12px 20px; border-bottom: 2px solid var(--neon); display: flex; justify-content: space-between; align-items: center; z-index: 10; }
        .logo { font-weight: bold; color: var(--neon); letter-spacing: 1px; }
        .controls { display: flex; gap: 10px; }

        /* Buttons */
        .btn { background: #222; color: var(--neon); border: 1px solid var(--neon); padding: 8px 15px; cursor: pointer; font-size: 11px; font-weight: bold; text-transform: uppercase; transition: 0.3s; }
        .btn:hover { background: var(--neon); color: #000; box-shadow: 0 0 10px var(--neon); }
        .btn-save { border-color: var(--accent); color: var(--accent); }
        .btn-save:hover { background: var(--accent); color: #fff; box-shadow: 0 0 10px var(--accent); }

        /* Main Layout */
        .main { display: grid; grid-template-columns: 320px 1fr; flex: 1; overflow: hidden; }

        /* Sidebar / Explorer */
        #explorer { background: var(--panel); border-right: 1px solid #333; overflow-y: auto; padding: 10px; display: flex; flex-direction: column; }
        .search-bar { background: #000; border: 1px solid #333; color: #fff; padding: 8px; margin-bottom: 10px; width: 100%; font-size: 12px; }
        .file-item { padding: 6px 10px; cursor: pointer; border-radius: 2px; font-size: 12px; border-bottom: 1px solid #222; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; color: #888; }
        .file-item:hover { background: #222; color: #fff; }
        .file-item.active { background: #333; color: var(--neon); border-left: 3px solid var(--neon); }

        /* Editor Area */
        #editor-container { display: flex; flex-direction: column; background: #050505; position: relative; }
        #textEditor { flex: 1; background: transparent; color: #0f8; border: none; padding: 20px; font-size: 14px; resize: none; outline: none; display: none; line-height: 1.5; }
        
        /* Preview & Replace Asset */
        #preview-pane { display: none; flex-direction: column; flex: 1; align-items: center; justify-content: center; padding: 40px; text-align: center; }
        #preview-pane img { max-width: 250px; max-height: 250px; margin-bottom: 20px; border: 1px solid #333; padding: 5px; }
        .asset-actions { background: #111; padding: 20px; border-radius: 8px; border: 1px dashed #444; }

        /* Loading Overlay */
        #overlay { position: fixed; top: 0; left: 0; width: 100%; height: 100%; background: rgba(0,0,0,0.8); display: none; flex-direction: column; align-items: center; justify-content: center; z-index: 100; }
        .loader { border: 4px solid #333; border-top: 4px solid var(--neon); border-radius: 50%; width: 40px; height: 40px; animation: spin 1s linear infinite; }
        @keyframes spin { 0% { transform: rotate(0deg); } 100% { transform: rotate(360deg); } }
    </style>
</head>
<body>

<div id="overlay"><div class="loader"></div><p id="loaderText">Processando...</p></div>

<header>
    <div class="logo">APO STUDIO V12 // <span id="currentProject">SEM PROJETO</span></div>
    <div class="controls">
        <input type="file" id="importFile" accept=".zip,.apk" style="display:none">
        <button class="btn" onclick="document.getElementById('importFile').click()">📦 IMPORTAR APK/ZIP</button>
        <button class="btn btn-save" onclick="exportProject()">🚀 BUILD NOVO APK</button>
    </div>
</header>

<div class="main">
    <div id="explorer">
        <input type="text" class="search-bar" placeholder="🔍 Buscar arquivo..." onkeyup="filterFiles(this.value)">
        <div id="fileList"></div>
    </div>
    
    <div id="editor-container">
        <textarea id="textEditor" spellcheck="false" placeholder="// Edite o código aqui..."></textarea>
        
        <div id="preview-pane">
            <div id="mediaContainer"></div>
            <div class="asset-actions">
                <p style="font-size: 12px; margin-bottom: 15px; color: #aaa;">Deseja trocar este arquivo?</p>
                <input type="file" id="replaceInput" style="display:none">
                <button class="btn" onclick="document.getElementById('replaceInput').click()">🔄 SUBSTITUIR ARQUIVO</button>
            </div>
        </div>

        <div style="font-size: 10px; padding: 5px 15px; background: #000; color: #444;" id="footerInfo">Ready.</div>
    </div>
</div>

<script>
    let zip = null;
    let currentPath = "";
    const loader = document.getElementById('overlay');

    // Carregar Arquivo Principal
    document.getElementById('importFile').addEventListener('change', async (e) => {
        const file = e.target.files[0];
        if (!file) return;
        
        showLoading("Descompactando projeto...");
        document.getElementById('currentProject').innerText = file.name.toUpperCase();

        try {
            const arrayBuffer = await file.arrayBuffer();
            zip = await JSZip.loadAsync(arrayBuffer);
            renderFileList();
        } catch (err) {
            alert("Erro ao carregar arquivo: " + err.message);
        }
        hideLoading();
    });

    // Listar Arquivos
    function renderFileList(filter = "") {
        const list = document.getElementById('fileList');
        list.innerHTML = "";
        
        Object.keys(zip.files).forEach(path => {
            if (zip.files[path].dir || (filter && !path.toLowerCase().includes(filter.toLowerCase()))) return;

            const div = document.createElement('div');
            div.className = 'file-item';
            div.innerText = path;
            div.onclick = () => openFile(path, div);
            list.appendChild(div);
        });
    }

    function filterFiles(val) { renderFileList(val); }

    // Abrir Arquivo Selecionado
    async function openFile(path, el) {
        currentPath = path;
        document.querySelectorAll('.file-item').forEach(i => i.classList.remove('active'));
        el.classList.add('active');

        const file = zip.file(path);
        const ext = path.split('.').pop().toLowerCase();
        
        // Reset Visuals
        document.getElementById('textEditor').style.display = "none";
        document.getElementById('preview-pane').style.display = "none";
        document.getElementById('footerInfo').innerText = `Path: ${path}`;

        if (['png', 'jpg', 'jpeg', 'gif', 'webp'].includes(ext)) {
            const blob = await file.async("blob");
            const url = URL.createObjectURL(blob);
            document.getElementById('mediaContainer').innerHTML = `<img src="${url}">`;
            document.getElementById('preview-pane').style.display = "flex";
        } 
        else if (['mp3', 'wav', 'ogg'].includes(ext)) {
            const blob = await file.async("blob");
            const url = URL.createObjectURL(blob);
            document.getElementById('mediaContainer').innerHTML = `<audio controls src="${url}"></audio>`;
            document.getElementById('preview-pane').style.display = "flex";
        }
        else {
            const content = await file.async("string");
            document.getElementById('textEditor').value = content;
            document.getElementById('textEditor').style.display = "block";
        }
    }

    // Salvar edições de texto no ZIP
    document.getElementById('textEditor').addEventListener('input', (e) => {
        if (zip && currentPath) {
            zip.file(currentPath, e.target.value);
        }
    });

    // Substituir Imagem ou Áudio
    document.getElementById('replaceInput').addEventListener('change', async (e) => {
        const file = e.target.files[0];
        if (!file || !currentPath) return;

        showLoading("Substituindo asset...");
        const reader = new FileReader();
        reader.onload = async (ev) => {
            zip.file(currentPath, ev.target.result); // Substitui no ZIP
            alert("Arquivo substituído com sucesso!");
            // Refresh preview
            const ext = currentPath.split('.').pop().toLowerCase();
            const url = URL.createObjectURL(new Blob([ev.target.result]));
            if (['png', 'jpg', 'jpeg', 'gif', 'webp'].includes(ext)) {
                document.getElementById('mediaContainer').innerHTML = `<img src="${url}">`;
            } else {
                document.getElementById('mediaContainer').innerHTML = `<audio controls src="${url}"></audio>`;
            }
            hideLoading();
        };
        reader.readAsArrayBuffer(file);
    });

    // Gerar Nova Versão (Build)
    async function exportProject() {
        if (!zip) return alert("Nenhum projeto carregado!");
        
        showLoading("Compilando nova versão... Isso pode demorar dependendo do tamanho.");
        
        const blob = await zip.generateAsync({type: "blob", compression: "DEFLATE"});
        const link = document.createElement('a');
        link.href = URL.createObjectURL(blob);
        link.download = "apo_mod_version.apk";
        link.click();
        
        hideLoading();
    }

    function showLoading(txt) { loader.style.display = "flex"; document.getElementById('loaderText').innerText = txt; }
    function hideLoading() { loader.style.display = "none"; }
</script>

</body>
</html>
